[app]
title = Gauravi
package.name = gauraviai
package.domain = org.gauravi
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 1.0

# कॉल, मैसेज और फोन कंट्रोल की ताकत
android.permissions = INTERNET, CALL_PHONE, READ_CONTACTS, READ_SMS, RECEIVE_SMS, SEND_SMS, RECORD_AUDIO, READ_PHONE_STATE, POST_NOTIFICATIONS, MODIFY_AUDIO_SETTINGS

orientation = portrait
fullscreen = 1
android.arch = arm64-v8a
android.api = 31
